# ============================================================
# MySQL Configuration - macOS Homebrew
# Location: /opt/homebrew/etc/my.cnf
# ============================================================

[client]
port            = 3306
socket          = /tmp/mysql.sock
default-character-set = utf8mb4

[mysqld]
# ── Port & Network ──────────────────────────────────────────
port            = 3306
bind-address    = 127.0.0.1
socket          = /tmp/mysql.sock

# ── User & Data Directory ───────────────────────────────────
user            = mysql
datadir         = /opt/homebrew/var/mysql

# ── Character Set ───────────────────────────────────────────
character-set-server  = utf8mb4
collation-server      = utf8mb4_unicode_ci

# ── Logging ─────────────────────────────────────────────────
log_error               = /opt/homebrew/var/mysql/error.log
slow_query_log          = 1
slow_query_log_file     = /opt/homebrew/var/mysql/slow.log
long_query_time         = 2
log_queries_not_using_indexes = 1
general_log             = 0
general_log_file        = /opt/homebrew/var/mysql/general.log

# ── Performance ─────────────────────────────────────────────
innodb_buffer_pool_size = 512M
innodb_log_file_size    = 128M
innodb_flush_log_at_trx_commit = 1
innodb_flush_method     = O_DIRECT
max_connections         = 200
query_cache_size        = 0
tmp_table_size          = 64M
max_heap_table_size     = 64M
thread_cache_size       = 16
table_open_cache        = 400

# ── Security ────────────────────────────────────────────────
skip-symbolic-links
local-infile            = 0

[mysqldump]
quick
max_allowed_packet      = 64M

[mysql]
default-character-set   = utf8mb4
