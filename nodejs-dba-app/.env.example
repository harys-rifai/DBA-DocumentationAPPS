# ===========================================================
# APPLICATION
# ===========================================================
APP_NAME=nodejs-dba-app
APP_PORT=3000
APP_ENV=development
JWT_SECRET=change_this_to_a_strong_random_secret
JWT_EXPIRES_IN=24h

# ===========================================================
# POSTGRESQL DATABASE
# ===========================================================
DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=runbookai
DB_USER=postgres
DB_PASS=your_postgres_password
DB_SCHEMA=ai
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# ===========================================================
# REDIS
# ===========================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USER=redis
REDIS_PASS=your_redis_password
REDIS_TTL=3600

# ===========================================================
# LOGGING
# ===========================================================
LOG_LEVEL=info
LOG_DIR=/opt/homebrew/var/log/app
