{
  "name": "nodejs-dba-app",
  "version": "2.0.0",
  "description": "Bun + Prisma + PostgreSQL DBA Management App with AI Handbook",
  "main": "src/app.js",
  "scripts": {
    "start": "bun run src/app.js",
    "dev": "bun --hot src/app.js",
    "build": "bun build src/app.js --outir dist",
    "prisma:generate": "bunx prisma generate",
    "prisma:migrate": "bunx prisma migrate dev",
    "prisma:reset": "bunx prisma migrate reset --force",
    "prisma:seed": "bun run prisma/seed.js",
    "migrate": "bun run prisma:migrate",
    "seed": "bun run prisma:seed"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "prisma": "^6.19.3"
  }
}
